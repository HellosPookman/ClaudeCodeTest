DATABASE_URL=postgresql://recon:recon_secret@localhost:5432/reconciliation
REDIS_URL=redis://localhost:6379/0

# S3-compatible storage (MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=reconciliation
S3_REGION=us-east-1

# Auth
SECRET_KEY=change-me-run-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=480

# OCR provider: mock | google | azure | aws
OCR_PROVIDER=mock

# Google Cloud Vision (if OCR_PROVIDER=google)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Azure Form Recognizer (if OCR_PROVIDER=azure)
AZURE_FORM_RECOGNIZER_ENDPOINT=
AZURE_FORM_RECOGNIZER_KEY=

# AWS Textract (if OCR_PROVIDER=aws)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-east-1

ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# PDF export branding
COMPANY_NAME=My Company
COMPANY_LOGO_URL=

# Matching / OCR thresholds (also configurable via admin UI)
AMOUNT_TOLERANCE_FIXED=20
AMOUNT_TOLERANCE_PCT=0.05
OCR_CONFIDENCE_AMOUNT=0.95
OCR_CONFIDENCE_DATE=0.90
OCR_CONFIDENCE_TIME=0.90
OCR_CONFIDENCE_INVOICE_NUMBER=0.95
BATCH_UPLOAD_THRESHOLD=20
RETENTION_DAYS=90
